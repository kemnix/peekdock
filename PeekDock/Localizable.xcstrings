    "onboarding.terms.howItWorks.bleed" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Be careful that content from other apps isn't captured unintentionally."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "他アプリのコンテンツが意図せず映り込まないようご注意ください。"
