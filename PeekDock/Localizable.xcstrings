    "onboarding.permission.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please allow Screen Recording in System Settings so PeekDock can capture the Zoom window."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PeekDockがZoomウィンドウをキャプチャできるよう、\nシステム設定で画面録画を許可してください。"
          }
        }
      }
    },
