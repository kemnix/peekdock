      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "During a meeting, click Capture. A region selector opens so you can crop to the slide area."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ミーティング中に「キャプチャ」をクリックすると、記録範囲を選ぶ画面が開きます。"
          }
        }
      }
    },
    "onboarding.tutorial.step2.title" : {
