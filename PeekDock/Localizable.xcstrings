    },
    "onboarding.terms.responsibility.compliance" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compliance with copyright, privacy, confidentiality, and other applicable laws or agreements — as well as proper handling of recorded data — is solely your responsibility."
