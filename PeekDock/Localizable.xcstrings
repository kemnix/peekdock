    "onboarding.tutorial.step1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hover over the notch at the top of your display to reveal the controls."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ディスプレイ上部のノッチにマウスを重ねるとコントロールが表示されます。"
          }
        }
      }
    },
