    },
    "onboarding.terms.howItWorks.storage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Captured slides are extracted from the Zoom window and temporarily saved to ~/Documents/PeekDock/. Discarding them in the review screen deletes the files."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャプチャした Zoom ウィンドウからスライドを抽出し、~/Documents/PeekDock/ に一時保存します。レビュー画面で破棄した場合は削除されます。"
          }
        }
      }
    },
