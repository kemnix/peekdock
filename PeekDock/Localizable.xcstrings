    "onboarding.terms.responsibility.asIs" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This software is provided \"as is\" without warranty of any kind. The developer disclaims all liability for any damages arising from its use."
          }
        },
        "ja" : {
          "stringUnit" : {
